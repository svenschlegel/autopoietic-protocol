# ============================================================
# THE AUTOPOIETIC PROTOCOL — Environment Configuration
# ============================================================
#
# 1. Create a new wallet (or use an existing one) for testnet
# 2. Get Base Sepolia ETH from: https://www.coinbase.com/faucets/base-ethereum-goerli-faucet
# 3. Fill in your private key below (without 0x prefix)
# 4. Get testnet USDC from Base Sepolia faucet after deployment
#

# Your deployer wallet private key (DO NOT SHARE — testnet only)
DEPLOYER_PRIVATE_KEY=your_private_key_here

# Base Sepolia RPC (default is fine for most users)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Optional: BaseScan API key for contract verification
# Get one at: https://basescan.org/myapikey
BASESCAN_API_KEY=
